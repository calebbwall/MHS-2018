# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/mhs2018

# JWT
JWT_SECRET=replace_with_32_or_more_random_characters_here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Email (Gmail App Password recommended)
# Enable 2FA on Gmail → Google Account → Security → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="MHS Class of 2018 <your.email@gmail.com>"
